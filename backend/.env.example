# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb+srv://baha:baha@cluster0.ytuptr5.mongodb.net/celiac-disease?appName=Cluster0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Validation locale des pièces jointes (déclaration patient) — OCR + PDF + score médical, sans API cloud
# CELIAC_DOC_AI=off          # désactive la validation (ex. développement)
# CELIAC_DOC_MIN_SCORE=18    # score minimum par fichier (baisser = plus permissif)
